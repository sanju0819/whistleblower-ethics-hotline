# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.

GROQ_API_KEY=your_groq_api_key_here
AI_PORT=5000
FLASK_DEBUG=false

# C-3 / I-11 FIX: Redis URL for rate-limiter shared state across Gunicorn workers.
# In Docker Compose this is redis://redis:6379 (matches the service name).
# Locally without Redis, leave this commented out — the limiter falls back to
# in-memory storage and logs a WARNING at startup.
REDIS_URL=redis://redis:6379

# Path where ChromaDB stores its persistent vector data.
# In Docker this maps to the volume defined in docker-compose.yml.
CHROMA_PERSIST_DIR=./chroma_data
